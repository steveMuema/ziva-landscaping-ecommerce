# Copy this file to .env and fill in values locally. Never commit .env or put production credentials here (repo may be public).
# Database (dev: docker compose up -d; host port 5434)
DATABASE_URL="postgresql://ziva:ziva_dev_secret@localhost:5434/ziva_landscaping"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# If you change NEXTAUTH_SECRET, existing session cookies won't decrypt—sign out (or clear site cookies) and sign in again.
NEXTAUTH_SECRET=48e40e0990929690bbcf7879f698e8586285e0b005763bc922307a2f3dfa3d9

# Google OAuth (optional). From OAuth web client JSON use web.client_id and web.client_secret for "Sign in with Google".
# In Google Cloud Console add redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Google Maps (optional). Create an API key in the same Cloud project; enable "Maps JavaScript API" and "Geocoding API".
# You can restrict the key by HTTP referrer or by OAuth 2.0 Client ID (use web.client_id from the OAuth file).
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Gemini AI for Fiona chat assistant (free tier). Get a key at https://ai.google.dev
# GOOGLE_AI_API_KEY=

ENCRYPTION_KEY=5a170442c315f0825d89b15da8ccc3584dfecabbd34b3b76bc581183b745b29f


# Encryption for Google credentials (Admin → Settings → Google credentials file upload).
# Generate a 64-char hex key: openssl rand -hex 32
# ENCRYPTION_KEY=

# Cloudinary (optional for dev)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# M-Pesa (optional for dev; required for STK Push)
# MPESA_ENV=sandbox
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSKEY=

# Site URL (for sitemap / M-Pesa callback)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
